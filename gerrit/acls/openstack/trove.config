[access]
	inheritFrom = openstack/meta-config

[access "refs/heads/*"]
	abandon = group trove-core
	label-Backport-Candidate = -1..+1 group trove-core
	label-Code-Review = -2..+2 group trove-core
	label-Verified = -1..+1 group trove-ci
	label-Workflow = -1..+1 group trove-core

[access "refs/heads/stable/*"]
	abandon = group Change Owner
	abandon = group Project Bootstrappers
	abandon = group stable-maint-core
	abandon = group trove-stable-maint
	exclusiveGroupPermissions = abandon label-Code-Review label-Workflow
	label-Code-Review = -2..+2 group Project Bootstrappers
	label-Code-Review = -2..+2 group stable-maint-core
	label-Code-Review = -2..+2 group trove-stable-maint
	label-Code-Review = -1..+1 group Registered Users
	label-Workflow = -1..+0 group Change Owner
	label-Workflow = -1..+1 group Project Bootstrappers
	label-Workflow = -1..+1 group stable-maint-core
	label-Workflow = -1..+1 group trove-stable-maint

[label "Backport-Candidate"]
	copyCondition = changekind:NO_CODE_CHANGE OR changekind:TRIVIAL_REBASE OR is:MAX OR is:MIN
	defaultValue = 0
	function = NoBlock
	value = -1 Not A Backport Candidate
	value = 0 Backport Review Needed
	value = +1 Proposed Backport

[submit-requirement "Backport-Candidate"]
	applicableIf = is:false
	description = Backport candidate status
	submittableIf = is:true
